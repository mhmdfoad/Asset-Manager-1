# =============================================================================
# Environment Variables — Next.js Storefront
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# WooCommerce API (Phase 2+)
# Consumer Key and Secret from WooCommerce → Settings → Advanced → REST API
# -----------------------------------------------------------------------------
WOOCOMMERCE_URL=https://your-wordpress-site.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# CoCart API (Phase 2+)
# Used for headless cart management
# -----------------------------------------------------------------------------
COCART_URL=https://your-wordpress-site.com

# -----------------------------------------------------------------------------
# JWT Auth (Phase 2+)
# Used to verify customer tokens
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key

# -----------------------------------------------------------------------------
# Webhook Secret (Phase 2+)
# Used to validate WooCommerce webhook signatures
# -----------------------------------------------------------------------------
WOOCOMMERCE_WEBHOOK_SECRET=your-webhook-secret

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=متجر
